#. Title of scan window
#: data/org.gnome.SimpleScan.desktop.in:2
#: data/org.gnome.SimpleScan.metainfo.xml.in:6 data/ui/app-window.ui:138
#: src/app-window.vala:1253
msgid "Document Scanner"
msgstr "ເຄື່ອງສະແກນເອກະສານ"

#: data/org.gnome.SimpleScan.desktop.in:3
#: data/org.gnome.SimpleScan.metainfo.xml.in:7
msgid "Make a digital copy of your photos and documents"
msgstr "ສ້າງສຳເນົາດິຈິຕອນຂອງຮູບພາບ ແລະ ເອກະສານຂອງທ່ານ"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.SimpleScan.desktop.in:5
msgid "scan;scanner;flatbed;adf;simple-scan;simplescan;"
msgstr "ສະແກນ;ເຄື່ອງສະແກນ;scan;scanner;flatbed;adf;simple-scan;simplescan;"

#: data/org.gnome.SimpleScan.gschema.xml:11
msgid "Device to scan from"
msgstr "ອຸປະກອນທີ່ຈະສະແກນຈາກ"

#: data/org.gnome.SimpleScan.gschema.xml:12
msgid "SANE device to acquire images from."
msgstr "ອຸປະກອນ SANE ທີ່ຈະຮັບຮູບພາບຈາກ."

#: data/org.gnome.SimpleScan.gschema.xml:20
msgid "Type of document being scanned"
msgstr "ປະເພດຂອງເອກະສານທີ່ກຳລັງສະແກນ"

#: data/org.gnome.SimpleScan.gschema.xml:21
msgid ""
"Type of document being scanned. This setting decides on the scan resolution, "
"colors and post-processing."
msgstr "ປະເພດຂອງເອກະສານທີ່ກຳລັງສະແກນ. ການຕັ້ງຄ່ານີ້ຈະກຳນົດຄວາມລະອຽດ, ສີ ແລະ ການປະມວນຜົນຫຼັງການສະແກນ."

#: data/org.gnome.SimpleScan.gschema.xml:25
msgid "Width of paper in tenths of a mm"
msgstr "ຄວາມກວ້າງຂອງເຈ້ຍໃນໜ່ວຍສ່ວນສິບຂອງມິນລີແມັດ"

#: data/org.gnome.SimpleScan.gschema.xml:26
msgid ""
"The width of the paper in tenths of a mm (or 0 for automatic paper "
"detection)."
msgstr "ຄວາມກວ້າງຂອງເຈ້ຍໃນໜ່ວຍສ່ວນສິບຂອງມິນລີແມັດ (ຫຼື 0 ສຳລັບການກວດຈັບຂະໜາດເຈ້ຍອັດຕະໂນມັດ)."

#: data/org.gnome.SimpleScan.gschema.xml:30
msgid "Height of paper in tenths of a mm"
msgstr "ຄວາມສູງຂອງເຈ້ຍໃນໜ່ວຍສ່ວນສິບຂອງມິນລີແມັດ"

#: data/org.gnome.SimpleScan.gschema.xml:31
msgid ""
"The height of the paper in tenths of a mm (or 0 for automatic paper "
"detection)."
msgstr "ຄວາມສູງຂອງເຈ້ຍໃນໜ່ວຍສ່ວນສິບຂອງມິນລີແມັດ (ຫຼື 0 ສຳລັບການກວດຈັບຂະໜາດເຈ້ຍອັດຕະໂນມັດ)."

#: data/org.gnome.SimpleScan.gschema.xml:35
msgid "Brightness of scan"
msgstr "ຄວາມສະຫວ່າງຂອງການສະແກນ"

#: data/org.gnome.SimpleScan.gschema.xml:36
msgid "The brightness adjustment from -100 to 100 (0 being none)."
msgstr "ການປັບຄວາມສະຫວ່າງຈາກ -100 ຫາ 100 (0 ຄືບໍ່ປັບ)."

#: data/org.gnome.SimpleScan.gschema.xml:40
msgid "Contrast of scan"
msgstr "ຄວາມຄົມຊັດຂອງການສະແກນ"

#: data/org.gnome.SimpleScan.gschema.xml:41
msgid "The contrast adjustment from -100 to 100 (0 being none)."
msgstr "ການປັບຄວາມຄົມຊັດຈາກ -100 ຫາ 100 (0 ຄືບໍ່ປັບ)."

#: data/org.gnome.SimpleScan.gschema.xml:45
msgid "Resolution for text scans"
msgstr "ຄວາມລະອຽດສຳລັບການສະແກນຂໍ້ຄວາມ"

#: data/org.gnome.SimpleScan.gschema.xml:46
msgid "The resolution in dots-per-inch to use when scanning text."
msgstr "ຄວາມລະອຽດໃນໜ່ວຍຈຸດຕໍ່ນິ້ວທີ່ຈະໃຊ້ເມື່ອສະແກນຂໍ້ຄວາມ."

#: data/org.gnome.SimpleScan.gschema.xml:50
msgid "Resolution for image scans"
msgstr "ຄວາມລະອຽດສຳລັບການສະແກນຮູບພາບ"

#: data/org.gnome.SimpleScan.gschema.xml:51
msgid "The resolution in dots-per-inch to use when scanning images."
msgstr "ຄວາມລະອຽດໃນໜ່ວຍຈຸດຕໍ່ນິ້ວທີ່ຈະໃຊ້ເມື່ອສະແກນຮູບພາບ."

#: data/org.gnome.SimpleScan.gschema.xml:55
msgid "Page side to scan"
msgstr "ດ້ານຂອງໜ້າເຈ້ຍທີ່ຈະສະແກນ"

#: data/org.gnome.SimpleScan.gschema.xml:56
msgid "The page side to scan."
msgstr "ດ້ານຂອງໜ້າເຈ້ຍທີ່ຈະສະແກນ."

#: data/org.gnome.SimpleScan.gschema.xml:60
msgid "Directory to save files to"
msgstr "ໄດເລກະທໍຣີທີ່ຈະບັນທຶກໄຟລ໌"

#: data/org.gnome.SimpleScan.gschema.xml:61
msgid ""
"The directory to save files to. Defaults to the documents directory if unset."
msgstr "ໄດເລກະທໍຣີທີ່ຈະບັນທຶກໄຟລ໌. ຄ່າເລີ່ມຕົ້ນແມ່ນໄດເລກະທໍຣີເອກະສານຖ້າບໍ່ໄດ້ຕັ້ງຄ່າ."

#: data/org.gnome.SimpleScan.gschema.xml:65
msgid "File format that is used for saving image files"
msgstr "ຮູບແບບໄຟລ໌ທີ່ໃຊ້ສຳລັບການບັນທຶກໄຟລ໌ຮູບພາບ"

#: data/org.gnome.SimpleScan.gschema.xml:66
msgid ""
"MIME type that is used for saving image files. Examples of supported MIME "
"types: image/jpeg, image/png, application/pdf"
msgstr "ປະເພດ MIME ທີ່ໃຊ້ສຳລັບການບັນທຶກໄຟລ໌ຮູບພາບ. ຕົວຢ່າງປະເພດ MIME ທີ່ຮອງຮັບ: image/jpeg, image/png, application/pdf"

#: data/org.gnome.SimpleScan.gschema.xml:71
msgid "Quality value to use for JPEG compression"
msgstr "ຄ່າຄຸນນະພາບທີ່ຈະໃຊ້ສຳລັບການບີບອັດ JPEG"

#: data/org.gnome.SimpleScan.gschema.xml:72
msgid "Quality value to use for JPEG compression."
msgstr "ຄ່າຄຸນນະພາບທີ່ຈະໃຊ້ສຳລັບການບີບອັດ JPEG."

#: data/org.gnome.SimpleScan.gschema.xml:77
msgid "Delay in millisecond between pages"
msgstr "ການໜ່ວງເວລາເປັນມິນລິວິນາທີລະຫວ່າງໜ້າ"

#: data/org.gnome.SimpleScan.gschema.xml:78
msgid "Delay in millisecond between pages."
msgstr "ການໜ່ວງເວລາເປັນມິນລິວິນາທີລະຫວ່າງໜ້າ."

#: data/org.gnome.SimpleScan.gschema.xml:82
msgid "Whether or not postprocessing is enabled"
msgstr "ເປີດໃຊ້ການປະມວນຜົນຫຼັງການສະແກນຫຼືບໍ່"

#: data/org.gnome.SimpleScan.gschema.xml:83
msgid "Whether or not postprocessing is enabled."
msgstr "ເປີດໃຊ້ການປະມວນຜົນຫຼັງການສະແກນຫຼືບໍ່."

#: data/org.gnome.SimpleScan.gschema.xml:87
msgid "The path to the postprocessing script"
msgstr "ເສັ້ນທາງໄປຫາສະຄຣິບປະມວນຜົນຫຼັງການສະແກນ"

#: data/org.gnome.SimpleScan.gschema.xml:88
msgid "The path to the postprocessing script."
msgstr "ເສັ້ນທາງໄປຫາສະຄຣິບປະມວນຜົນຫຼັງການສະແກນ."

#: data/org.gnome.SimpleScan.gschema.xml:92
msgid "Additional arguments for the postprocessing script"
msgstr "ອາຣ໌ກິວເມນເພີ່ມເຕີມສຳລັບສະຄຣິບປະມວນຜົນຫຼັງການສະແກນ"

#: data/org.gnome.SimpleScan.gschema.xml:93
msgid "Additional arguments for the postprocessing script."
msgstr "ອາຣ໌ກິວເມນເພີ່ມເຕີມສຳລັບສະຄຣິບປະມວນຜົນຫຼັງການສະແກນ."

#: data/org.gnome.SimpleScan.gschema.xml:97
msgid "Whether or not to keep the original, unprocessed file"
msgstr "ຈະເກັບໄຟລ໌ຕົ້ນສະບັບທີ່ບໍ່ໄດ້ປະມວນຜົນໄວ້ຫຼືບໍ່"

#: data/org.gnome.SimpleScan.gschema.xml:98
msgid ""
"Whether or not to keep the original, unprocessed file. The \"_orig\" "
"filename will be added to the filename immediately before the file extension."
msgstr "ຈະເກັບໄຟລ໌ຕົ້ນສະບັບທີ່ບໍ່ໄດ້ປະມວນຜົນໄວ້ຫຼືບໍ່. ຊື່ໄຟລ໌ \"_orig\" ຈະຖືກຕື່ມເຂົ້າໄປກ່ອນນາມສະກຸນຂອງໄຟລ໌."

#: data/org.gnome.SimpleScan.metainfo.xml.in:9
msgid ""
"A really easy way to scan both text and images. You can crop out the bad "
"parts of an image and rotate it if it is the wrong way round. You can print "
"your scans, export them to pdf, or save them in a range of image formats."
msgstr "ວິທີທີ່ງ່າຍດາຍໃນການສະແກນທັງຂໍ້ຄວາມ ແລະ ຮູບພາບ. ທ່ານສາມາດຕັດສ່ວນທີ່ບໍ່ຕ້ອງການຂອງຮູບພາບອອກ ແລະ ໝູນມັນໄດ້ຖ້າຫາກມັນປີ້ນດ້ານ. ທ່ານສາມາດພິມສິ່ງທີ່ສະແກນ, ສົ່ງອອກເປັນ pdf, ຫຼື ບັນທຶກໃນຮູບແບບໄຟລ໌ຮູບພາບຕ່າງໆໄດ້."

#: data/org.gnome.SimpleScan.metainfo.xml.in:14
msgid "This app uses the SANE framework to support most existing scanners."
msgstr "ແອັບນີ້ໃຊ້ SANE framework ເພື່ອຮອງຮັບເຄື່ອງສະແກນສ່ວນໃຫຍ່ທີ່ມີຢູ່."

